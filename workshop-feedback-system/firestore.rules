rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin Helper
    function isAdmin() {
      // Allow any authenticated user during development since custom claims aren't set
      return request.auth != null;
    }

    // Workshops: Public read, Admin write
    match /workshops/{formId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Submissions: Admin read/update/delete, Client create allowed
    // (Temporarily allowing client creation for testing)
    match /submissions/{submissionId} {
      allow read, update, delete: if isAdmin();
      allow create: if true;
    }

    // OTPs: No client access
    match /otps/{otpId} {
      allow read, write: if false;
    }
  }
}
